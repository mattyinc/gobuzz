NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Confirmation emails via Resend (resend.com). Leave empty to skip sending —
# bookings still succeed without it.
RESEND_API_KEY=
# Must be a verified sender/domain in Resend. Falls back to onboarding@resend.dev
# (test mode: only delivers to the Resend account owner's address).
BOOKING_FROM_EMAIL="Go'Buzz Wellness <bookings@gobuzzwellness.com>"

# Absolute site URL used inside emails and QR deep links.
# Falls back to the request origin when empty.
NEXT_PUBLIC_SITE_URL=

# Optional. Used by GitHub Pages static export only.
NEXT_PUBLIC_BASE_PATH=/gobuzz
